# Copy this file to ".env" and fill in real values.
# NEVER commit your real .env — it is gitignored.

# Port the API listens on (local dev default 4000)
PORT=4000

# Secret used to sign login tokens. MUST be set to a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# How long a "remember me" login stays valid.
JWT_EXPIRES_IN=30d

# Where the SQLite database file lives. Default keeps it next to the backend, outside git.
DB_PATH=./data/ledger.db

# Comma-separated list of frontend origins allowed to call this API.
# Local dev Vite default is http://localhost:5173
CORS_ORIGINS=http://localhost:5173
